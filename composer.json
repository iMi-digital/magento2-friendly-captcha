{
    "name": "imi/magento2-friendly-captcha",
    "description": "Friendly Captcha integration for Magento2",
    "require": {
        "php": ">=8.1",
        "ext-intl": ">=1.0.0",
        "magento/framework": "^103.0.0",
        "magento/module-contact": "^100.4.0",
        "magento/module-customer": "^102.0.0|^103.0.0",
        "magento/module-checkout": "^100.3.0",
        "magento/module-newsletter": "^100.3.0"
    },
    "authors": [
        {
            "name": "Daniel Galla",
            "email": "d.galla@imi.de"
        }
    ],
    "type": "magento2-module",
    "license": "OSL-3.0",
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "IMI\\FriendlyCaptcha\\": ""
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "scripts": {
        "phpcsfixer:check": "php-cs-fixer fix --dry-run --diff",
        "phpcsfixer:fix": "php-cs-fixer fix"
    }
}
